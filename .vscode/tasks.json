{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Python: Build",
            "command": "python scripts/build.py",
            "type": "shell",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Python: Toggle noLib",
            "command": "python scripts/toggleNoLib.py",
            "type": "shell"
        },
        {
            "label": "Git: Add Submodule",
            "type": "shell",
            "command": "git submodule add ${input:gitURL} ${input:submodulePath}"
        },
        {
            "label": "Python: Download Dependencies",
            "type": "shell",
            "command": "python scripts/dependencies.py"
        },
        {
            "label": "Python: Update all Dependencies",
            "type": "shell",
            "command": "python scripts/dependencies.py -u"
        },
        {
            "label": "Python: Update dependencies & Build",
            "dependsOn": [
                "Python: Update all Dependencies",
                "Python: Build"
            ],
            "type": "shell",
            "command": "echo \"Updated and Built!\""
        }
    ],
    "inputs": [
        {
            "id": "gitURL",
            "type": "promptString",
            "description": "The Git URI / URL"
        },
        {
            "id": "submodulePath",
            "type": "promptString",
            "description": "The path on your drive to insert the submodule",
            "default": "lib/submodule"
        }
    ]
}